# ─────────────────────────────────────────────────────────────────
# Confidential — never commit
# ─────────────────────────────────────────────────────────────────
# Strategy + execution notes (specific to current case-study cycle)
strategy.md

# Buyer-specific top-layer framing (per-cycle, never committed)
*_steps.md
*_instructions.md

# Source case-study briefs (copyrighted, do not redistribute)
case_study/
*.pdf

# Cover note drafts addressed to a specific recipient
cover_note.md
cover_note_*.md

# Internal evaluation reports (third-party reviewer perspective; per-cycle, contains buyer name)
report.md
report_*.md

# Case-study report template (per-cycle, may contain buyer-specific framing — see CLAUDE.md § 6)
docs/case_study_report_template.md

# Phase 2.5 cloud-acceptance evidence artifacts (per-run; AWS account IDs, ARNs,
# private IPs, CloudWatch metric snapshots). Selected screenshots/excerpts get
# pasted into docs/deployment_guide.md by hand; the full dump never commits.
evidence/

# Leak-guard pattern file (one regex per line of buyer-specific tokens)
.leakguard

# Claude harness state (transient lock files, schedule tracking)
.claude/

# ─────────────────────────────────────────────────────────────────
# Local environment
# ─────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.local

# WireGuard keys / configs with material
wireguard/*.conf
wireguard/keys/
wireguard/config/
!wireguard/wg0.conf.template

# Terraform state + plan output (state holds secrets, plan is per-machine).
# Use **/ patterns so nested modules (e.g. terraform/bootstrap/) are also
# covered — provider binaries can hit 700+MB and would blow GitHub's
# per-file 100MB limit.
**/.terraform/
**/.terraform.lock.hcl
terraform/*.tfstate
terraform/*.tfstate.*
terraform/**/*.tfstate
terraform/**/*.tfstate.*
terraform/*.tfplan
terraform/**/*.tfplan
terraform/*.tfvars
terraform/**/*.tfvars
!terraform/*.tfvars.example
!terraform/**/*.tfvars.example
terraform/crash.log
terraform/**/crash.log

# Cloud screenshots (may contain account IDs, IPs, ARNs)
screenshots/
*.screenshot.png

# easy-rsa PKI tree generated by scripts/bootstrap-vpn-certs.sh — contains
# CA root key + per-operator client keys. Never commit (ADR-0024).
pki/
*.crt
*.key
*.pem
!terraform/*.crt.example
!terraform/*.key.example

# ─────────────────────────────────────────────────────────────────
# Language / tool defaults
# ─────────────────────────────────────────────────────────────────
# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
.venv/
venv/
.python-version

# Node (if any tooling)
node_modules/

# IDE
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~

# Logs
*.log
logs/
.venv-test/
