# Local development environment variables.
# Copy to .env (gitignored) and adjust. In the cloud, credentials resolve via
# the ECS task IAM role / standard AWS credential chain — never commit real values.

# DynamoDB — local dev points at the dynamodb-local container (see docker-compose.yml).
DYNAMODB_TABLE_NAME=aegis-enclave-executions
AWS_ENDPOINT_URL=http://dynamodb-local:8000
AWS_DEFAULT_REGION=eu-central-1

LOG_LEVEL=INFO
APP_VERSION=1.0.0
